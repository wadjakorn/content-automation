{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LaneC.FactCheckVerdict",
  "type": "object",
  "required": ["surface", "claim", "type", "verdict", "requires_human"],
  "properties": {
    "surface": { "enum": ["script", "transcript"] },
    "claim": { "type": "string" },
    "type": { "enum": ["spec_numeric", "price", "comparative", "superlative", "causal_technical", "temporal"] },
    "verdict": { "enum": ["SUPPORTED", "REFUTED", "NOT_ENOUGH_INFO"] },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tier", "url"],
        "properties": {
          "tier": { "type": "integer", "enum": [1, 2, 3] },
          "url": { "type": "string" },
          "snippet": { "type": "string" }
        }
      }
    },
    "correct_value": { "type": ["string", "null"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "requires_human": { "type": "boolean" }
  }
}
